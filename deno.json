{
  "name": "@dreamer/queue",
  "version": "1.1.0",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE.md",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**"
    ]
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.1.2",
    "@dreamer/test": "jsr:@dreamer/test@^1.2.3",
    "@dreamer/service": "jsr:@dreamer/service@^1.1.0",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.2.2",
    "mongodb": "npm:mongodb@7.0.0",
    "redis": "npm:redis@5.10.0",
    "amqplib": "npm:amqplib@0.10.9",
    "memcache-client": "npm:memcache-client@1.0.5"
  },
  "tasks": {
    "test": "deno test -A tests/",
    "test:unit": "deno test -A tests/adapter-interface.test.ts tests/delay.test.ts tests/mod.test.ts tests/performance.test.ts tests/priority.test.ts tests/queue-manager.test.ts tests/queue.test.ts",
    "test:integration": "deno test -A tests/memcached.test.ts tests/mongodb.test.ts tests/rabbitmq.test.ts tests/redis.test.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/"
  },
  "nodeModulesDir": "auto",
  "minimumDependencyAge": 0,
  "compilerOptions": {
    "strict": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns",
      "deno.window"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}

{
  "name": "@dreamer/queue",
  "version": "1.0.0-beta.7",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@dreamer/test": "jsr:@dreamer/test@^1.0.0-beta.13",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@1.0.0-beta.17",
    "mongodb": "npm:mongodb@^7.0.0",
    "redis": "npm:redis@^5.0.0",
    "amqplib": "npm:amqplib@^0.10.9",
    "memcache-client": "npm:memcache-client@^1.0.0"
  },
  "unstable": [
    "cron"
  ],
  "publish": {
    "include": [
      "src/**/*.ts",
      "LICENSE.md",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}

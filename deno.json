{
  "name": "@dreamer/queue",
  "version": "1.0.1",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE.md",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**"
    ]
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.0.1",
    "@dreamer/test": "jsr:@dreamer/test@^1.0.11",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.15",
    "mongodb": "npm:mongodb@7.0.0",
    "redis": "npm:redis@5.10.0",
    "amqplib": "npm:amqplib@0.10.9",
    "memcache-client": "npm:memcache-client@1.0.5"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}

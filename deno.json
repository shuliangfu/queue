{
  "name": "@dreamer/queue",
  "version": "1.0.0-beta.1",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@dreamer/test": "jsr:@dreamer/test@1.0.0-beta.6",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.0-beta.2",
    "mongodb": "npm:mongodb@^6.0.0"
  },
  "unstable": [
    "cron"
  ],
  "publish": {
    "include": [
      "src/mod.ts",
      "LICENSE.md",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
